{
  "manifest_version": 3,
  "name": "SAIPOS Tools",
  "version": "1.0.0",
  "description": "Ferramentas SAIPOS: exportar notas de entrada e conciliar itens de NF-e.",
  "permissions": [
    "activeTab",
    "scripting",
    "storage",
    "downloads"
  ],
  "host_permissions": [
    "*://*.saipos.com/*",
    "*://*/*"
  ],
  "background": {
    "service_worker": "src/background.ts",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["*://*.saipos.com/*"],
      "js": ["src/content/saiposContent.ts"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "src/popup/index.html",
    "default_icon": {
      "16":  "icon16.png",
      "48":  "icon48.png",
      "128": "icon128.png"
    }
  },
  "options_page": "src/options/index.html",
  "icons": {
    "16":  "icon16.png",
    "48":  "icon48.png",
    "128": "icon128.png"
  }
}
